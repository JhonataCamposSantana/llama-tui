{
  "llama_server": "~/llama.cpp/build/bin/llama-server",
  "vllm_command": "vllm",
  "hf_cache_root": "~/.cache/huggingface/hub",
  "llmfit_cache_root": "~/.cache/llmfit/models",
  "llm_models_cache_root": "~/.cache/llm-models",
  "lm_studio_model_roots": "~/.lmstudio/models, ~/.lmstudio/hub/models",
  "opencode": {
    "path": "~/.config/opencode/opencode.json",
    "backup_dir": "~/.config/llama-tui/backups",
    "timeout": 600000,
    "chunk_timeout": 60000,
    "instructions": [
      "./instructions/warm.md"
    ],
    "build_prompt": "{file:./prompts/friendly-build.txt}",
    "plan_prompt": "{file:./prompts/friendly-build.txt}",
    "default_model_id": "local-example",
    "small_model_id": "local-example",
    "build_model_id": "local-example",
    "plan_model_id": "local-example",
    "terminal_command": "",
    "last_workspace_path": ""
  },
  "models": [
    {
      "id": "local-example",
      "name": "Local Example Q4 K M",
      "path": "~/.cache/llm-models/local-example-q4_k_m.gguf",
      "alias": "local-example-q4-k-m",
      "port": 8080,
      "host": "127.0.0.1",
      "ctx": 2048,
      "threads": 6,
      "ngl": 0,
      "temp": 0.7,
      "parallel": 1,
      "cache_ram": 0,
      "flash_attn": true,
      "jinja": true,
      "output": 2048,
      "optimize_mode": "max_context_safe",
      "optimize_tier": "safe",
      "ctx_min": 2048,
      "ctx_max": 131072,
      "memory_reserve_percent": 40,
      "benchmark_fingerprint": "",
      "default_benchmark_status": "pending",
      "default_benchmark_at": "",
      "enabled": true,
      "runtime": "llama.cpp",
      "source": "manual",
      "extra_args": []
    }
  ]
}
